{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<feed xmlns="http://www.w3.org/2005/Atom">

 <title>{{ site.Title }}</title>
 <link href="{{ "atom.xml" | absURL }}" rel="self"/>
 <link href="{{ site.BaseURL }}"/>
 <updated>{{ now.Format "2006-01-02T15:04:05Z07:00" }}</updated>
 <id>{{ site.BaseURL }}</id>
 <author>
   <name>Adrian Scripcă</name>
   <email></email>
 </author>

 {{ range where site.RegularPages "Type" "posts" }}
 {{ $c := .Summary }}{{ with .Params.excerpt }}{{ $c = ( . | markdownify ) }}{{ end }}
 <entry>
   <title>{{ .Title }}</title>
   <link href="{{ .Permalink }}"/>
   <updated>{{ .Date.Format "2006-01-02T15:04:05Z07:00" }}</updated>
   <id>{{ .Permalink }}</id>
   <content type="html">{{ transform.HTMLEscape $c | safeHTML }}</content>
 </entry>
 {{ end }}

</feed>
